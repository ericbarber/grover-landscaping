# Local application settings
APP_ENV=local
PORT=8080
HOST_UID=1000
HOST_GID=1000
FRONTEND_DIST_DIR=../frontend/dist

# Frontend
VITE_API_BASE_URL=http://localhost:8080

# Backend
RUST_LOG=grover_landscaping_api=debug,tower_http=debug
# Host-run backend and database tooling connect through the published PostgreSQL port.
DATABASE_URL=postgres://grover:grover@localhost:5432/grover_landscaping
# The backend container connects to PostgreSQL through the Compose network.
COMPOSE_DATABASE_URL=postgres://grover:grover@postgres:5432/grover_landscaping
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Authentication. Use disabled only for seed-data development and automated tests.
AUTH_MODE=disabled
# AUTH_MODE=cognito
# COGNITO_ISSUER_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_example
# COGNITO_CLIENT_ID=exampleclientid
# COGNITO_LOGIN_DOMAIN=https://grover-landscaping-dev-example.auth.us-east-1.amazoncognito.com

# Notification dispatcher. Disabled by default; webhook mode requires the URLs below.
NOTIFICATION_DISPATCH_MODE=disabled
PUBLIC_APP_URL=http://localhost:5173
# NOTIFICATION_WEBHOOK_URL=https://notifications.example.com/deliver
# NOTIFICATION_WEBHOOK_BEARER_TOKEN=replace-with-provider-gateway-token
# VALIDATE_NOTIFICATION_WEBHOOK_DELIVERY=0
# NOTIFICATION_WEBHOOK_SMOKE_CHANNEL=email
# NOTIFICATION_WEBHOOK_SMOKE_RECIPIENT=customer@example.com
NOTIFICATION_POLL_SECONDS=5
NOTIFICATION_BATCH_SIZE=10
NOTIFICATION_MAX_ATTEMPTS=5

# Photo evidence storage. Local placeholder is the default for development.
PHOTO_STORAGE_MODE=local
# PHOTO_STORAGE_MODE=s3
# S3_PHOTO_BUCKET=grover-landscaping-dev-photos
# S3_PHOTO_REGION=us-east-1
# S3_PHOTO_KEY_PREFIX=photos
# S3_PHOTO_UPLOAD_EXPIRES_SECONDS=900
# S3_PHOTO_DISPLAY_EXPIRES_SECONDS=900
# AWS_ACCESS_KEY_ID=replace-with-upload-signing-key
# AWS_SECRET_ACCESS_KEY=replace-with-upload-signing-secret
# AWS_SESSION_TOKEN=

# Photo processing worker. Enable only with DATABASE_URL and PHOTO_STORAGE_MODE=s3.
PHOTO_PROCESSING_WORKER_MODE=disabled
# PHOTO_PROCESSING_WORKER_MODE=enabled
PHOTO_PROCESSING_POLL_SECONDS=10
PHOTO_PROCESSING_BATCH_SIZE=5
PHOTO_PROCESSING_MAX_ATTEMPTS=5

# Local database
POSTGRES_DB=grover_landscaping
POSTGRES_USER=grover
POSTGRES_PASSWORD=grover
